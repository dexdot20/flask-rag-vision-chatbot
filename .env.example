DEEPSEEK_API_KEY=your-deepseek-api-key

# Optional: change where SQLite and Chroma persist data.
# CHROMA_DB_PATH=/absolute/path/to/chroma_db
# IMAGE_STORAGE_DIR=./data/images
# AGENT_TRACE_LOG_PATH=./logs/agent-trace.log
# DOCUMENT_STORAGE_DIR=./data/documents

# Optional: BGE-M3 embedding configuration.
# BGE_M3_MODEL_PATH=BAAI/bge-m3
# BGE_M3_DEVICE=cpu
# BGE_M3_LOCAL_FILES_ONLY=false
# BGE_M3_TRUST_REMOTE_CODE=false
# BGE_M3_BATCH_SIZE=32
# BGE_M3_PRELOAD=true

# Optional: local Qwen vision/OCR configuration.
# QWEN_VL_MODEL_PATH=/absolute/path/to/Qwen2.5-VL-7B-Instruct
# QWEN_VL_ATTENTION=flash_attention_2
# QWEN_VL_LOAD_IN_4BIT=true
# QWEN_VL_TORCH_DTYPE=float16
# QWEN_VL_MAX_NEW_TOKENS=768
# QWEN_VL_MIN_PIXELS=200704
# QWEN_VL_MAX_PIXELS=802816
# QWEN_VL_MAX_IMAGE_SIDE=1280
# QWEN_VL_PRELOAD=true

# Optional: RAG tuning.
# RAG_ENABLED=true
# RAG_AUTO_INJECT_TOP_K=5
# RAG_SEARCH_DEFAULT_TOP_K=5
# RAG_AUTO_INJECT_THRESHOLD=0.35
# RAG_SEARCH_MIN_SIMILARITY=0.2

# Optional: fetch/summary tuning.
# FETCH_SUMMARY_TOKEN_THRESHOLD=3500
# FETCH_SUMMARY_MAX_CHARS=8000
# FETCH_SUMMARY_GENERAL_TOP_K=3
# FETCH_SUMMARY_QUERY_TOP_K=4
# FETCH_SUMMARY_EXCERPT_MAX_CHARS=500
# FETCH_RAW_TOOL_RESULT_MAX_TEXT_CHARS=24000

# Optional: chat summary tuning.
# CHAT_SUMMARY_TRIGGER_TOKEN_COUNT=80000
# CHAT_SUMMARY_BATCH_SIZE=20
# CHAT_SUMMARY_MODE=auto
# CHAT_SUMMARY_MODEL=deepseek-chat

# Optional: feature flags.
# VISION_ENABLED=true
# SCRATCHPAD_ADMIN_EDITING_ENABLED=false
